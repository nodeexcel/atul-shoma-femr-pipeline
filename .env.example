# Copy this file to .env (local) or .env.prod (production) and fill in values.

# Host user — keeps bind-mount files owned by you instead of root
UID=1000
GID=1000

# Django core
SECRET_KEY=replace-with-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Logging
DJANGO_LOG_LEVEL=INFO

# File upload limit in MB (default: 50)
MAX_UPLOAD_SIZE_MB=50

# Celery broker (Redis) — default works with Docker Compose setup
CELERY_BROKER_URL=redis://redis:6379/0

# Path to the repo root inside Docker — scripts/ and docs/ are mounted here
# Leave as /repo when using Docker Compose; change to actual path on bare metal
FEMR_REPO_ROOT=/repo

# PostgreSQL database
DB_NAME=shoma
DB_USER=shoma
DB_PASSWORD=shoma_dev
DB_HOST=db
DB_PORT=5432

# For prod, also set these on the postgres service (used as POSTGRES_* vars):
# POSTGRES_DB=shoma
# POSTGRES_USER=shoma
# POSTGRES_PASSWORD=<strong-password>

# Oracle APEX OAuth credentials — required for FEMR export API calls
# Obtain from Josh Grapani (NextFlex tech lead)
ORACLE_CLIENT_ID=
ORACLE_SECRET_KEY=
